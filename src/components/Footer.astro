---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="footer-lockup" aria-label="Farlink Systems home">
        <img src="/logo-mark.png" alt="" class="footer-mark" />
        <div>
          <strong>Farlink Systems LLC</strong>
          <p>Industrial controls, electrical testing, arc flash studies, and field support.</p>
        </div>
      </a>
    </div>

    <div>
      <span class="label">Pages</span>
      <nav class="footer-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>

    <div>
      <span class="label">Contact</span>
      <div class="footer-links">
        <a href="mailto:info@farlinksystems.com">info@farlinksystems.com</a>
        <a href="#" class="phone-link" data-p1="843" data-p2="901" data-p3="7138"></a>
        <span>885 Gold Hill Rd<br />Fort Mill, SC 29708</span>
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {year} Farlink Systems LLC</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 2.5rem 0 1.5rem;
    border-top: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.28);
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
  }

  .footer-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    max-width: 32rem;
  }

  .footer-mark {
    width: 3rem;
    height: auto;
    flex: 0 0 auto;
  }

  .footer-lockup strong {
    display: block;
    color: var(--brand);
    font-size: 1rem;
  }

  .footer-lockup p {
    margin-top: 0.35rem;
    font-size: var(--text-sm);
  }

  .footer-links {
    display: grid;
    gap: 0.55rem;
    margin-top: 0.8rem;
    color: var(--text-soft);
  }

  .footer-links a:hover {
    color: var(--brand);
  }

  .footer-bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  @media (min-width: 760px) {
    .footer-grid {
      grid-template-columns: minmax(0, 2fr) 1fr 1fr;
      align-items: start;
    }
  }
</style>

<script>
  document.querySelectorAll('.phone-link').forEach((el) => {
    const p1 = el.dataset.p1;
    const p2 = el.dataset.p2;
    const p3 = el.dataset.p3;
    const num = p1 + '-' + p2 + '-' + p3;
    el.textContent = num;
    el.href = 'tel:+1' + p1 + p2 + p3;
  });
</script>
