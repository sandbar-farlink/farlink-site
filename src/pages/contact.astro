---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Farlink Systems about automation, testing, arc flash studies, or field support.">
  <section class="page-intro">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Tell us what you are working on.</h1>
      <p>
        Email is usually the fastest way to start. If you already have drawings, photos, one-lines, or a rough scope, send them.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="stack">
        <article class="card info-card">
          <span class="eyebrow">Reach out directly</span>
          <div class="contact-list">
            <div>
              <span class="kicker">Email</span>
              <a href="mailto:info@farlinksystems.com" class="contact-value">info@farlinksystems.com</a>
            </div>

            <div>
              <span class="kicker">Phone</span>
              <a href="#" class="contact-value phone-link" data-p1="843" data-p2="901" data-p3="7138"></a>
            </div>

            <div>
              <span class="kicker">Address</span>
              <span class="contact-value">885 Gold Hill Rd<br />Fort Mill, SC 29708</span>
            </div>
          </div>
        </article>

        <article class="card info-card">
          <span class="eyebrow">Typical work</span>
          <ul class="list-reset checklist compact-list">
            <li>Controls and automation</li>
            <li>Electrical testing and commissioning</li>
            <li>Arc flash and power studies</li>
            <li>Water, commercial, industrial, and government sites</li>
          </ul>
        </article>
      </div>

      <div class="stack">
        <article class="surface callout">
          <span class="eyebrow">Helpful details to send</span>
          <ul class="list-reset checklist compact-list">
            <li>Site location and type of facility</li>
            <li>What is being built, tested, studied, or fixed</li>
            <li>Schedule or outage window</li>
            <li>Drawings, one-lines, panel lists, or photos if you have them</li>
          </ul>
        </article>

        <article class="card info-card">
          <span class="eyebrow">Prefer email?</span>
          <p>
            Put the basics in the note. We can sort out the next step from there.
          </p>
          <div class="button-row">
            <a href="mailto:info@farlinksystems.com?subject=Farlink%20project%20inquiry" class="btn">Email Us</a>
          </div>
        </article>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .contact-list {
    display: grid;
    gap: 1.1rem;
    margin-top: 1rem;
  }

  .contact-value {
    display: inline-block;
    margin-top: 0.25rem;
    color: var(--brand);
    font-size: var(--text-lg);
    word-break: break-word;
  }

  .contact-value:hover {
    color: var(--accent);
  }

  .compact-list {
    margin-top: 0.9rem;
  }

  @media (min-width: 860px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 2rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.phone-link').forEach((el) => {
    const p1 = el.dataset.p1;
    const p2 = el.dataset.p2;
    const p3 = el.dataset.p3;
    const num = p1 + '-' + p2 + '-' + p3;
    el.textContent = num;
    el.href = 'tel:+1' + p1 + p2 + p3;
  });
</script>
